    <!-- ================= CONTROLLERS ================= -->
<!-- ================= CONTROLLERS ================= -->
    <!-- Torque Control for base_joint (Rotation) -->
    <plugin
      filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>base_joint</joint_name>
    </plugin>

    <!-- Torque Control for joint1 (Shoulder) -->
    <plugin
      filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>joint1</joint_name>
    </plugin>

    <!-- Torque Control for joint2 (Elbow) -->
    <plugin
      filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>joint2</joint_name>
    </plugin>

    <!-- Torque Control for joint3 (Wrist Pitch) -->
    <plugin
      filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>joint3</joint_name>
    </plugin>

    <!-- Torque Control for joint4 (Wrist Roll) -->
    <plugin
      filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>joint4</joint_name>
    </plugin>

    <!-- Feedback System: Publishes position/velocity of all joints -->
    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
    </plugin>

    <!-- Torque Control for finger1 -->
    <plugin
      filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>finger1_joint</joint_name>
    </plugin>

    <!-- Torque Control for finger2 -->
    <plugin
      filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>finger2_joint</joint_name>
    </plugin>
